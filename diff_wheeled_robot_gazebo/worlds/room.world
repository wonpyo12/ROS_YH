<?xml version="1.0" ?>

<sdf version="1.5">

  <world name="room">

    <!-- 조명 -->

    <include>

      <uri>model://sun</uri>

    </include>

    <!-- 바닥 -->

    <include>

      <uri>model://ground_plane</uri>

    </include>

    <!-- 방 벽 4개 (4m x 4m) -->

    <!-- 전방 벽 (x=+2) -->

    <model name="wall_front">

      <static>true</static>

      <pose>2 0 0.5 0 0 0</pose>

      <link name="link">

        <collision name="collision">

          <geometry><box><size>0.1 4 1</size></box></geometry>

        </collision>

        <visual name="visual">

          <geometry><box><size>0.1 4 1</size></box></geometry>

          <material>

            <ambient>0.8 0.8 0.8 1</ambient>

          </material>

        </visual>

      </link>

    </model>

    <!-- 후방 벽 (x=-2) -->

    <model name="wall_back">

      <static>true</static>

      <pose>-2 0 0.5 0 0 0</pose>

      <link name="link">

        <collision name="collision">

          <geometry><box><size>0.1 4 1</size></box></geometry>

        </collision>

        <visual name="visual">

          <geometry><box><size>0.1 4 1</size></box></geometry>

          <material>

            <ambient>0.8 0.8 0.8 1</ambient>

          </material>

        </visual>

      </link>

    </model>

    <!-- 좌측 벽 (y=+2) -->

    <model name="wall_left">

      <static>true</static>

      <pose>0 2 0.5 0 0 0</pose>

      <link name="link">

        <collision name="collision">

          <geometry><box><size>4 0.1 1</size></box></geometry>

        </collision>

        <visual name="visual">

          <geometry><box><size>4 0.1 1</size></box></geometry>

          <material>

            <ambient>0.8 0.8 0.8 1</ambient>

          </material>

        </visual>

      </link>

    </model>

    <!-- 우측 벽 (y=-2) -->

    <model name="wall_right">

      <static>true</static>

      <pose>0 -2 0.5 0 0 0</pose>

      <link name="link">

        <collision name="collision">

          <geometry><box><size>4 0.1 1</size></box></geometry>

        </collision>

        <visual name="visual">

          <geometry><box><size>4 0.1 1</size></box></geometry>

          <material>

            <ambient>0.8 0.8 0.8 1</ambient>

          </material>

        </visual>

      </link>

    </model>
  <model name="obstacle_1">

  <static>true</static>

  <pose>1 0.5 0.5 0 0 0</pose>

  <link name="link">

    <collision name="collision">

      <geometry><cylinder><radius>0.15</radius><length>1</length></cylinder></geometry>

    </collision>

    <visual name="visual">

      <geometry><cylinder><radius>0.15</radius><length>1</length></cylinder></geometry>

      <material>

        <ambient>0.8 0.2 0.2 1</ambient>

      </material>

    </visual>

  </link>

</model>

  </world>

</sdf>

