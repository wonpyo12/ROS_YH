<?xml version="1.0" ?>
<sdf version="1.5">
  <world name="test2">

    <!-- 조명 + 바닥 -->
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- ===== 외벽 (8m x 8m 정사각형) ===== -->

    <!-- 하단 벽 (y=-4) -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>8 0.1 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>8 0.1 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- 상단 벽 (y=4) -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>8 0.1 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>8 0.1 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- 왼쪽 벽 (x=-4) -->
    <model name="wall_west">
      <static>true</static>
      <pose>-4 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.1 8 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 8 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- 오른쪽 벽 (x=4) -->
    <model name="wall_east">
      <static>true</static>
      <pose>4 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.1 8 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 8 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ===== 중앙 장애물 (2m x 2m 박스) ===== -->
    <model name="center_box">
      <static>true</static>
      <pose>0 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>2 2 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2 2 1</size></box></geometry>
          <material><ambient>0.3 0.3 0.8 1</ambient></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>